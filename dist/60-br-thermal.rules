# Brother thermal printer USB access for br-thermal service
#
# AUTO-GENERATED by cmake/GenerateUdevRules.cmake — do not edit by hand.
# Source of truth: usb-ids.cmake files in each driver directory.
#
# Grants the _br-thermal system user read/write access to supported devices,
# tags them with uaccess so the logged-in desktop user can also access them,
# and starts br-thermal.service when any supported printer is plugged in.
#
# Reload after changes:
#   udevadm control --reload-rules && udevadm trigger --subsystem-match=usb

# TD-2020
ACTION=="add", SUBSYSTEM=="usb", ATTRS{idVendor}=="04f9", ATTRS{idProduct}=="2055", GROUP="_br-thermal", MODE="0660", TAG+="uaccess", TAG+="systemd", ENV{SYSTEMD_WANTS}="br-thermal-autoadd.service"
